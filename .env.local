# Writheon environment variables
# This is a static HTML site deployed on Vercel.
# Process.env is NOT available in browser HTML at runtime.
# Set the value directly in the JS constant STRIPE_PAYMENT_LINK
# inside public/coverage/index.html (search for STRIPE_PAYMENT_LINK_HERE).
#
# For any serverless functions (api/*.js), these ARE available via process.env.
# Add them in Vercel Dashboard → Project Settings → Environment Variables.

NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
STRIPE_FOUNDING_LINK=https://buy.stripe.com/fZu9ATh2s8Fv7lW8th7bW01
ANTHROPIC_API_KEY=
