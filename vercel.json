{
  "version": 2,
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/stripe-webhook", "dest": "/api/stripe-webhook" },
    { "src": "/api/notion-export", "dest": "/api/notion-export" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/coverage", "dest": "/coverage/index.html" },
    { "src": "/coverage/(.*)", "dest": "/coverage/$1" },
    { "src": "/advisor", "dest": "/advisor/index.html" },
    { "src": "/advisor/(.*)", "dest": "/advisor/$1" },
    { "src": "/rewrite", "dest": "/rewrite/index.html" },
    { "src": "/rewrite/(.*)", "dest": "/rewrite/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
